<%- partial('_partial/head') %>

<body>
  <main class="content">
    <%- body %>
    <%- partial('_partial/footer') %>
  </main>
  <aside class="sidebar">
    <%- partial('_partial/sidebar', null, {cache: !config.relative_link}) %>
  </aside>
  <%- partial('_partial/after-footer') %>
</body>

</html>

<!-- Desktop-only visual effects. Disabled on mobile and WeChat to keep the page lightweight. -->
<canvas class="fireworks desktop-effects" style="position: fixed;left: 0;top: 0;z-index: 1; pointer-events: none;"></canvas>
<script>
  (function () {
    var ua = navigator.userAgent || '';
    var isMobile = /Android|iPhone|iPad|iPod|Mobile/i.test(ua);
    var isWeChat = /MicroMessenger/i.test(ua);

    if (isMobile || isWeChat) {
      var canvas = document.querySelector('.desktop-effects');
      if (canvas) canvas.parentNode.removeChild(canvas);
      return;
    }

    function loadScript(src) {
      var script = document.createElement('script');
      script.src = src;
      script.async = true;
      document.body.appendChild(script);
    }

    loadScript('https://cdn.bootcdn.net/ajax/libs/animejs/2.2.0/anime.min.js');
    loadScript('https://cdn.jsdelivr.net/gh/snorlaxse/jsDeliver/js/click/fireworks.js');
    loadScript('https://cdn.jsdelivr.net/gh/snorlaxse/jsDeliver/js/sakura.js');
  })();
</script>
